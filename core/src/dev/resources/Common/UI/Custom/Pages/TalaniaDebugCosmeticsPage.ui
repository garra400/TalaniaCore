$C = "../Common.ui";

$C.@Panel {
  LayoutMode: Top;
  Anchor: (Width: 864, Height: 672);
  Padding: (Full: 16);

  Group #CosmeticsPanel {
    LayoutMode: Top;
    Anchor: (Width: 826, Height: 634);
    Padding: (Full: 12);

    Label #TitleLabel {
      Style: (...$C.@TitleStyle, FontSize: 20);
      Anchor: (Width: 520);
      Text: "Talania Cosmetics";
      Padding: (Bottom: 6);
    }

    Label #SubtitleLabel {
      Style: (...$C.@DefaultLabelStyle);
      Anchor: (Width: 520);
      Text: "Dev build only. Toggle cosmetics and isolate attachments.";
      Padding: (Bottom: 10);
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 32);

      $C.@SecondaryTextButton #HideBaseButton { Text: "Hide Base: Off"; Anchor: (Width: 160, Height: 28); }
      $C.@SecondaryTextButton #StripBaseButton { Text: "Strip Base: Off"; Anchor: (Width: 160, Height: 28, Left: 10); }
      $C.@SecondaryTextButton #ViewModeButton { Text: "View Mode"; Anchor: (Width: 140, Height: 28, Left: 10); }
    }

    Group #CosmeticsScroll {
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;
      Anchor: (Width: 768, Height: 456);
      Padding: (Full: 2, Top: 10);

      Group #Cosmetic1Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic1Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 1"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic1Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic2Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic2Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 2"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic2Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic3Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic3Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 3"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic3Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic4Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic4Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 4"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic4Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic5Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic5Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 5"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic5Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic6Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic6Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 6"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic6Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic7Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic7Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 7"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic7Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic8Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic8Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 8"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic8Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic9Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic9Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 9"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic9Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }

      Group #Cosmetic10Container {
        LayoutMode: Left;
        Anchor: (Width: 768, Height: 48, Top: 6);
        Padding: (Full: 6);
        Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

        Label #Cosmetic10Label { Style: (...$C.@DefaultLabelStyle); Text: "Cosmetic 10"; Anchor: (Width: 540); }
        $C.@SecondaryTextButton #Cosmetic10Toggle { Text: "Show"; Anchor: (Width: 110, Height: 28, Left: 10); }
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 32, Top: 10);
      $C.@SecondaryTextButton #ReturnButton { Text: "Return"; Anchor: (Width: 120, Height: 28); }
    }
  }
}
