$C = "../Common.ui";

@RaceTabLabelStyle = (
  ...$C.@DefaultLabelStyle,
  FontSize: 20,
  RenderBold: true,
  TextColor: #d3d6db,
  HorizontalAlignment: Center,
  VerticalAlignment: Center
);

@RaceTabStyle = TextButtonStyle(
  Default: (LabelStyle: @RaceTabLabelStyle),
  Hovered: (LabelStyle: (...@RaceTabLabelStyle, TextColor: #eaebee)),
  Pressed: (LabelStyle: (...@RaceTabLabelStyle, TextColor: #b6bbc2))
);

$C.@Panel {
  LayoutMode: Top;
  Anchor: (Width: 920, Height: 680);
  Padding: (Full: 16);

  Group {
    LayoutMode: Top;
    Anchor: (Width: 888, Height: 648);
    Padding: (Full: 12);

    Label #TitleLabel {
      Style: (...$C.@TitleStyle, FontSize: 32, HorizontalAlignment: Center);
      Anchor: (Width: 840);
      Text: "Choose a race";
      Padding: (Bottom: 6);
    }

    Group #TitleSeparator {
      Anchor: (Width: 860, Height: 2, Top: 6);
      Background: #2A313C;
    }

    Group #RaceTabs {
      LayoutMode: Top;
      Anchor: (Width: 860, Height: 108);
      Padding: (Full: 4);

      Group {
        LayoutMode: Center;
        Anchor: (Width: 860, Height: 32);
        Padding: (Full: 4);

        TextButton #HumanTabButton { Text: "Human"; Style: @RaceTabStyle; Anchor: (Width: 140, Height: 28); }
        TextButton #HighElfTabButton { Text: "High Elf"; Style: @RaceTabStyle; Anchor: (Width: 160, Height: 28); }
        TextButton #OrcTabButton { Text: "Orc"; Style: @RaceTabStyle; Anchor: (Width: 120, Height: 28); }
      }

      Group {
        LayoutMode: Center;
        Anchor: (Width: 860, Height: 32, Top: 8);
        Padding: (Full: 4);

        TextButton #DwarfTabButton { Text: "Dwarf"; Style: @RaceTabStyle; Anchor: (Width: 140, Height: 28); }
        TextButton #NightwalkerTabButton { Text: "Nightwalker"; Style: @RaceTabStyle; Anchor: (Width: 180, Height: 28); }
        TextButton #BeastkinTabButton { Text: "Beastkin"; Style: @RaceTabStyle; Anchor: (Width: 140, Height: 28); }
      }

      Group {
        LayoutMode: Center;
        Anchor: (Width: 860, Height: 32, Top: 8);
        Padding: (Full: 4);

        TextButton #StarbornTabButton { Text: "Starborn"; Style: @RaceTabStyle; Anchor: (Width: 140, Height: 28); }
      }
    }

    Group #Separator {
      Anchor: (Width: 860, Height: 2, Top: 8);
      Background: #2A313C;
    }

    Group #RaceDetails {
      LayoutMode: Top;
      Anchor: (Width: 860, Height: 340, Top: 10);
      Padding: (Full: 6);

      Label #RaceName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 28, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Width: 820);
        Text: "Race Name";
        Padding: (Bottom: 2);
      }
      Label #RaceTheme {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, TextColor: #a9b4c0, HorizontalAlignment: Center);
        Anchor: (Width: 820);
        Text: "Theme";
        Padding: (Bottom: 8);
      }
      Label #RaceHistory {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, Wrap: true, HorizontalAlignment: Left);
        Anchor: (Width: 820);
        Text: "History";
        Padding: (Bottom: 10);
      }
      Label #RaceBuffName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, RenderBold: true, TextColor: #ffffff, HorizontalAlignment: Left);
        Anchor: (Width: 820);
        Text: "Buff Name";
        Padding: (Bottom: 2);
      }
      Label #RaceBuffDesc {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, Wrap: true, HorizontalAlignment: Left);
        Anchor: (Width: 820);
        Text: "Buff Description";
        Padding: (Bottom: 10);
      }
      Label #RaceDebuffName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, RenderBold: true, TextColor: #ffffff, HorizontalAlignment: Left);
        Anchor: (Width: 820);
        Text: "Debuff Name";
        Padding: (Bottom: 2);
      }
      Label #RaceDebuffDesc {
        Style: (...$C.@DefaultLabelStyle, FontSize: 20, Wrap: true, HorizontalAlignment: Left);
        Anchor: (Width: 820);
        Text: "Debuff Description";
      }
    }

    Group {
      LayoutMode: Center;
      Anchor: (Height: 32, Top: 30);
      $C.@SecondaryTextButton #SelectButton { Text: "Confirm"; Anchor: (Width: 140, Height: 32); }
    }
  }
}
