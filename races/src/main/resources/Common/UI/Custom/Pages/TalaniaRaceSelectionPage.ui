$C = "../Common.ui";

$C.@Panel {
  LayoutMode: Top;
  Anchor: (Width: 920, Height: 680);
  Padding: (Full: 16);

  Group {
    LayoutMode: Top;
    Anchor: (Width: 888, Height: 648);
    Padding: (Full: 12);

    Label #TitleLabel {
      Style: (...$C.@TitleStyle, FontSize: 28);
      Anchor: (Width: 840);
      Text: "Choose a race";
      Padding: (Bottom: 6);
    }

    Group #TitleSeparator {
      Anchor: (Width: 860, Height: 2, Top: 6);
      Background: #2A313C;
    }

    Group #RaceTabs {
      LayoutMode: Top;
      Anchor: (Width: 860, Height: 108);
      Padding: (Full: 4);

      Group {
        LayoutMode: Left;
        Anchor: (Width: 860, Height: 32);
        Padding: (Full: 4);

        $C.@SecondaryTextButton #HumanTabButton { Text: "Human"; Anchor: (Width: 140, Height: 28); }
        $C.@SecondaryTextButton #HighElfTabButton { Text: "High Elf"; Anchor: (Width: 140, Height: 28, Left: 6); }
        $C.@SecondaryTextButton #OrcTabButton { Text: "Orc"; Anchor: (Width: 140, Height: 28, Left: 6); }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Width: 860, Height: 32, Top: 8);
        Padding: (Full: 4);

        $C.@SecondaryTextButton #DwarfTabButton { Text: "Dwarf"; Anchor: (Width: 140, Height: 28); }
        $C.@SecondaryTextButton #NightwalkerTabButton { Text: "Nightwalker"; Anchor: (Width: 160, Height: 28, Left: 6); }
        $C.@SecondaryTextButton #BeastkinTabButton { Text: "Beastkin"; Anchor: (Width: 140, Height: 28, Left: 6); }
      }

      Group {
        LayoutMode: Left;
        Anchor: (Width: 860, Height: 32, Top: 8);
        Padding: (Full: 4);

        $C.@SecondaryTextButton #StarbornTabButton { Text: "Starborn"; Anchor: (Width: 140, Height: 28); }
      }
    }

    Group #Separator {
      Anchor: (Width: 860, Height: 2, Top: 8);
      Background: #2A313C;
    }

    Group #RaceDetails {
      LayoutMode: Top;
      Anchor: (Width: 860, Height: 340, Top: 10);
      Padding: (Full: 6);

      Label #RaceName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 26, RenderBold: true);
        Anchor: (Width: 820);
        Text: "Race Name";
        Padding: (Bottom: 2);
      }
      Label #RaceTheme {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18, TextColor: #a9b4c0);
        Anchor: (Width: 820);
        Text: "Theme";
        Padding: (Bottom: 8);
      }
      Label #RaceHistory {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18);
        Anchor: (Width: 820);
        Text: "History";
        Padding: (Bottom: 10);
      }
      Label #RaceBuffName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #ffffff);
        Anchor: (Width: 820);
        Text: "Buff Name";
        Padding: (Bottom: 2);
      }
      Label #RaceBuffDesc {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18);
        Anchor: (Width: 820);
        Text: "Buff Description";
        Padding: (Bottom: 10);
      }
      Label #RaceDebuffName {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18, RenderBold: true, TextColor: #ffffff);
        Anchor: (Width: 820);
        Text: "Debuff Name";
        Padding: (Bottom: 2);
      }
      Label #RaceDebuffDesc {
        Style: (...$C.@DefaultLabelStyle, FontSize: 18);
        Anchor: (Width: 820);
        Text: "Debuff Description";
      }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 32, Top: 30);
      $C.@SecondaryTextButton #SelectButton { Text: "Confirm"; Anchor: (Width: 140, Height: 32); }
    }
  }
}
