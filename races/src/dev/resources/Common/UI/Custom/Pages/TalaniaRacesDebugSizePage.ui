$C = "../Common.ui";

$C.@Panel {
  LayoutMode: Top;
  Anchor: (Width: 864, Height: 624);
  Padding: (Full: 16);

  Group {
    LayoutMode: Top;
    Anchor: (Width: 826, Height: 586);
    Padding: (Full: 12);

    Label #TitleLabel {
      Style: (...$C.@TitleStyle, FontSize: 20);
      Anchor: (Width: 768);
      Text: "Races: Player Size";
      Padding: (Bottom: 6);
    }

    Label #SubtitleLabel {
      Style: (...$C.@DefaultLabelStyle);
      Anchor: (Width: 768);
      Text: "Sets the final PLAYER_SCALE value for this player.";
      Padding: (Bottom: 12);
    }

    Label #BaseScaleLabel {
      Style: (...$C.@DefaultLabelStyle);
      Anchor: (Width: 768);
      Text: "Base (race+mods): 1.00";
      Padding: (Bottom: 4);
    }

    Label #DebugScaleLabel {
      Style: (...$C.@DefaultLabelStyle);
      Anchor: (Width: 768);
      Text: "Debug multiplier: x1.00";
      Padding: (Bottom: 4);
    }

    Label #FinalScaleLabel {
      Style: (...$C.@DefaultLabelStyle);
      Anchor: (Width: 768);
      Text: "Final size: 1.00";
      Padding: (Bottom: 16);
    }

    Group {
      LayoutMode: Left;
      Anchor: (Width: 768, Height: 40);
      Padding: (Full: 6);
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

      Label { Style: (...$C.@DefaultLabelStyle); Text: "Adjust"; Anchor: (Width: 520); }
      $C.@SecondaryTextButton #ScaleMinusButton { Text: "-0.05"; Anchor: (Width: 120, Height: 28, Left: 10); }
      $C.@SecondaryTextButton #ScalePlusButton { Text: "+0.05"; Anchor: (Width: 120, Height: 28, Left: 10); }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Width: 768, Height: 40, Top: 10);
      Padding: (Full: 6);
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

      Label { Style: (...$C.@DefaultLabelStyle); Text: "Presets"; Anchor: (Width: 320); }
      $C.@SecondaryTextButton #ScaleDwarfButton { Text: "0.60"; Anchor: (Width: 120, Height: 28, Left: 10); }
      $C.@SecondaryTextButton #ScaleHumanButton { Text: "1.00"; Anchor: (Width: 120, Height: 28, Left: 10); }
      $C.@SecondaryTextButton #ScaleOrcButton { Text: "1.40"; Anchor: (Width: 120, Height: 28, Left: 10); }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Width: 768, Height: 40, Top: 10);
      Padding: (Full: 6);
      Background: (TexturePath: "../Common/ContainerPanelPatch.png", Border: 4);

      Label { Style: (...$C.@DefaultLabelStyle); Text: "Reset to 1.00"; Anchor: (Width: 520); }
      $C.@SecondaryTextButton #ScaleResetButton { Text: "Reset"; Anchor: (Width: 120, Height: 28, Left: 10); }
    }

    Group {
      LayoutMode: Left;
      Anchor: (Height: 32, Top: 12);
      $C.@SecondaryTextButton #ReturnButton { Text: "Return"; Anchor: (Width: 120, Height: 28); }
    }
  }
}
